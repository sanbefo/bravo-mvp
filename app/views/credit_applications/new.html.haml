.max-w-2xl.mx-auto.px-4.py-12
  -# Header
  .mb-8.text-center
    %h1.text-3xl.font-bold.text-main-text New Credit Application
    %p.text-gray-500.mt-2 Please fill in the details below to submit your request for review.

  -# Form Card
  .bg-white.shadow-2xl.rounded-2xl.border.border-highlight.p-8
    = form_with model: @application, class: "space-y-6" do |f|
      .space-y-2
        = f.label :country, class: "block text-sm font-semibold text-primary"
        = f.select :country, CreditApplication.countries.keys, {}, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :full_name, class: "block text-sm font-semibold text-primary"
        = f.text_field :full_name, placeholder: "John Doe", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :document_id, "Official ID / Document Number", class: "block text-sm font-semibold text-primary"
        = f.text_field :document_id, placeholder: "e.g. 123456789", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .pt-4.border-t.border-highlight
        .grid.grid-cols-1.md:grid-cols-2.gap-6
          .space-y-2
            = f.label :requested_amount, "Requested Amount ($)", class: "block text-sm font-semibold text-primary"
            .relative
              .absolute.inset-y-0.left-0.pl-3.flex.items-center.pointer-events-none
                %span.text-gray-500.sm:text-sm $
              = f.number_field :requested_amount, class: "w-full rounded-lg border-gray-300 pl-7 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
          .space-y-2
            = f.label :monthly_income, "Monthly Income ($)", class: "block text-sm font-semibold text-primary"
            .relative
              .absolute.inset-y-0.left-0.pl-3.flex.items-center.pointer-events-none
                %span.text-gray-500.sm:text-sm $
              = f.number_field :monthly_income, class: "w-full rounded-lg border-gray-300 pl-7 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .pt-6
        = f.submit "Submit Application", class: "w-full bg-primary hover:bg-secondary text-white font-bold py-3 px-6 rounded-xl shadow-lg transition duration-200 transform hover:-translate-y-0.5 cursor-pointer"
        .mt-4.text-center
          = link_to "Cancel and return", credit_applications_path, class: "text-sm text-gray-400 hover:text-primary transition"
