.max-w-6xl.mx-auto.px-4.py-8
  -# Search and Filter Row
  .mb-6.flex.justify-end
    .w-full.max-w-xs
      = label_tag :user_search, "Search Users", class: "block text-xs font-bold text-primary uppercase tracking-widest mb-2"
      = form_with url: users_path, method: :get, data: { turbo_frame: "users_table", turbo_action: "advance" }, class: "relative" do |f|
        = f.text_field :query, value: params[:query], placeholder: "Search by name or document...",
          class: "w-full pl-4 pr-10 py-2.5 bg-white border border-highlight rounded-xl shadow-sm focus:ring-2 focus:ring-accent focus:border-accent text-sm font-medium text-text-main",
          oninput: "this.form.requestSubmit()"
        .pointer-events-none.absolute.inset-y-0.right-0.flex.items-center.px-3.text-primary
          %svg.w-4.h-4{fill: "none", stroke: "currentColor", viewBox: "0 0 24 24"}
            %path{d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z", "stroke-width": "2", "stroke-linecap": "round", "stroke-linejoin": "round"}
  -# Header
  .flex.justify-between.items-center.mb-8
    %div
      %h1.text-3xl.font-bold.text-gray-900 Platform Users
      %p.text-sm.text-gray-500 View and manage registered user accounts.
    .flex.gap-3
      = link_to credit_applications_path, class: "bg-primary hover:bg-secondary text-white px-6 py-2.5 rounded-lg font-semibold transition duration-200 shadow-sm flex items-center gap-2" do
        ← Back to Applications
  = turbo_frame_tag "users_table" do
    .bg-white.shadow-md.rounded-xl.overflow-hidden.border.border-highlight
      %table.w-full.text-left.border-collapse
        %thead.bg-highlight
          %tr
            %th.px-6.py-5.text-xs.font-black.uppercase.tracking-widest.text-primary
              = sortable_link "id", "ID"
            %th.px-6.py-5.text-xs.font-black.uppercase.tracking-widest.text-primary
              = sortable_link "first_name", "Full Name"
            %th.px-6.py-5.text-xs.font-black.uppercase.tracking-widest.text-primary
              = sortable_link "email", "Email"
            %th.px-6.py-5.text-xs.font-black.uppercase.tracking-widest.text-primary
              = sortable_link "document", "Document ID"
            %th.px-6.py-5.text-xs.font-black.uppercase.tracking-widest.text-primary
              = sortable_link "created_at", "User Since"
            %th.px-6.py-4.text-xs.font-bold.uppercase.tracking-wider.text-primary Actions
        %tbody.divide-y.divide-highlight
          - @users.each do |user|
            %tr.hover:bg-gray-50.transition-colors
              %td.px-6.py-4.text-sm.font-medium.text-gray-400= "##{user.id}"
              %td.px-6.py-4
                .flex.flex-col
                  %span.text-sm.font-bold.text-gray-900= "#{user.first_name} #{user.last_name}".titleize
              %td.px-6.py-4
                .flex.flex-col
                  %span.text-sm= user.email
              %td.px-6.py-4
                .flex.flex-col
                  %span.text-sm= user.document.presence || "No Document"
              %td.px-6.py-4.text-sm.text-gray-500
                = user.created_at.strftime("%b %d, %Y")
              %td.px-6.py-4
                .flex.items-center.gap-4
                  = link_to user_path(user.slug), class: "text-accent hover:text-secondary font-bold text-sm flex items-center gap-1", data: { turbo: false } do
                    View
                    %span →
          .mt-8.flex.justify-center.pb-8
            .pagy-custom
              != pagy_nav(@pagy) if @pagy.pages > 1
