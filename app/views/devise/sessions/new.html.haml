.max-w-md.mx-auto.px-4.py-16
  -# Header
  .mb-8.text-center
    %h1.text-3xl.font-bold.text-main-text Welcome Back
    %p.text-gray-500.mt-2 Please enter your credentials to access the site.

  -# Login Card
  .bg-white.shadow-2xl.rounded-2xl.border.border-highlight.p-8
    = form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f|

      .space-y-2
        = f.label :email, class: "block text-sm font-semibold text-primary"
        = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@company.com",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"

      .space-y-2
        .flex.justify-between.items-center
          = f.label :password, class: "block text-sm font-semibold text-primary"
          - if devise_mapping.recoverable?
            = link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-gray-400 hover:text-accent transition"
        = f.password_field :password, autocomplete: "current-password", placeholder: "••••••••",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"

      - if devise_mapping.rememberable?
        .flex.items-center.gap-2
          = f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent cursor-pointer"
          = f.label :remember_me, class: "text-sm text-gray-500 cursor-pointer"

      .pt-4
        = f.submit "Log in", class: "w-full bg-primary hover:bg-secondary text-white font-bold py-3 px-6 rounded-xl shadow-lg transition duration-200 transform hover:-translate-y-0.5 cursor-pointer"

        .mt-6.pt-6.border-t.border-highlight.text-center
          %p.text-sm.text-gray-500
            Don't have an account?
            = link_to "Sign up", new_registration_path(resource_name), class: "font-semibold text-accent hover:text-primary transition"

    .mt-4.text-center
      = link_to "Back to home", root_path, class: "text-xs text-gray-400 hover:text-primary transition"
