.max-w-md.mx-auto.px-4.py-16
  .mb-8.text-center
    %h1.text-3xl.font-bold.text-main-text Create Account
    %p.text-gray-500.mt-2 Join us to start your credit application process.
  .bg-white.shadow-2xl.rounded-2xl.border.border-highlight.p-8
    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f|
      = render "devise/shared/error_messages", resource: resource
      .space-y-2
        = f.label :first_name, class: "block text-sm font-semibold text-primary"
        = f.text_field :first_name, autofocus: true, placeholder: "John",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :last_name, class: "block text-sm font-semibold text-primary"
        = f.text_field :last_name, autofocus: true, placeholder: "Doe",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :document, class: "block text-sm font-semibold text-primary"
        = f.text_field :document, autofocus: true, placeholder: "Your Document Id",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :email, class: "block text-sm font-semibold text-primary"
        = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@company.com",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      .space-y-2
        = f.label :password, class: "block text-sm font-semibold text-primary"
        = f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      -# Password Confirmation Field
      .space-y-2
        = f.label :password_confirmation, class: "block text-sm font-semibold text-primary"
        = f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-main-text py-2.5"
      -# Submit Action
      .pt-4
        = f.submit "Sign up", class: "w-full bg-primary hover:bg-secondary text-white font-bold py-3 px-6 rounded-xl shadow-lg transition duration-200 transform hover:-translate-y-0.5 cursor-pointer"
        .mt-6.pt-6.border-t.border-highlight.text-center
          %p.text-sm.text-gray-500
            Already have an account?
            = link_to "Log in", new_session_path(resource_name), class: "font-semibold text-accent hover:text-primary transition"
    .mt-4.text-center
      = link_to "Back to home", root_path, class: "text-xs text-gray-400 hover:text-primary transition"
